{
  "_schema": {
    "description": "All Avana training programs — past and upcoming combined. The site computes 'past' vs 'upcoming' at render time by comparing program.date to today (no status flag to flip). Add/edit/remove via the catalogue editor (_tools/catalog-editor.html → Training tab).",
    "fields": {
      "slug": "kebab-case identifier; ALSO the photo folder name under images/training/",
      "name": "Public-facing program title",
      "date": "ISO date YYYY-MM-DD. If date < today → renders as Past. If date >= today → renders as Upcoming.",
      "endDate": "Optional ISO date for multi-day programs",
      "doctors": "Array of strings — faculty / faculty teams",
      "place": "City, State (e.g. 'Chennai, Tamil Nadu')",
      "venue": "Optional — specific hospital / centre",
      "activities": "Array of activity slugs from controlledVocab.activities below",
      "description": "1–2 sentence summary (optional)",
      "highlights": "Optional array of 2–4 bullet points (best for past programs)",
      "photoCount": "Number of photos in images/training/{slug}/ named 01.jpg … NN.jpg. Page renders all with onerror=hide so any missing numbers vanish.",
      "photoFolder": "Auto-set to images/training/{slug}/ — kept here so loader doesn't have to compose it",
      "registrationUrl": "Optional — for upcoming programs only. If omitted, the page falls back to a mailto: link."
    }
  },
