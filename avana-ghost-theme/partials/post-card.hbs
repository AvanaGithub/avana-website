{{! Reusable post card — used on index, tag, and author pages }}
<article class="post-card {{#unless feature_image}}post-card--no-image{{/unless}}">
    {{#if feature_image}}
    <a href="{{url}}" class="post-card__image" tabindex="-1" aria-hidden="true">
        <img src="{{img_url feature_image size="s"}}"
             alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
             loading="lazy">
    </a>
    {{/if}}
    <div class="post-card__body">
        {{#primary_tag}}
        <a href="{{url}}" class="post-card__tag">{{name}}</a>
        {{/primary_tag}}
        <h2 class="post-card__title">
            <a href="{{url}}">{{title}}</a>
        </h2>
        <p class="post-card__excerpt">{{excerpt words="25"}}</p>
        <div class="post-card__meta">
            {{#primary_author}}
            <img class="post-card__avatar"
                 src="{{#if profile_image}}{{img_url profile_image size="xs"}}{{else}}{{asset "images/avatar-default.png"}}{{/if}}"
                 alt="{{name}}"
                 loading="lazy">
            <span class="post-card__author">{{name}}</span>
            {{/primary_author}}
            <span class="post-card__sep">·</span>
            <time class="post-card__date" datetime="{{date format="YYYY-MM-DD"}}">
                {{date format="DD MMM YYYY"}}
            </time>
            <span class="post-card__sep">·</span>
            <span class="post-card__read-time">{{reading_time}}</span>
        </div>
    </div>
</article>
