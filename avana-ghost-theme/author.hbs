{{!< default}}

{{! Author archive page }}

<section class="archive-hero">
    <div class="container">
        {{#author}}
        <div class="author-archive-head">
            <img class="author-archive-head__avatar"
                 src="{{#if profile_image}}{{profile_image}}{{else}}{{asset "images/avatar-default.png"}}{{/if}}"
                 alt="{{name}}">
            <div>
                <span class="blog-hero__eyebrow">Author</span>
                <h1 class="blog-hero__title">{{name}}</h1>
                {{#if bio}}<p class="archive-hero__desc">{{bio}}</p>{{/if}}
                {{#if location}}<p class="author-archive-head__location">📍 {{location}}</p>{{/if}}
                <p class="archive-hero__count">{{plural ../pagination.total empty="No posts" singular="% post" plural="% posts"}}</p>
            </div>
        </div>
        {{/author}}
    </div>
</section>

<section class="blog-listing">
    <div class="container">
        <div class="post-grid">
            {{#foreach posts}}
            {{> post-card}}
            {{/foreach}}
        </div>
        {{> pagination}}
    </div>
</section>
