{{!< default}}

{{!-- Static page — same as post but without tag/author/date chrome. --}}

{{#post}}
<article class="post-full post-full--page {{#unless feature_image}}post-full--no-image{{/unless}}">

    {{#if feature_image}}
        {{#if @page.show_title_and_feature_image}}
        <div class="post-full__cover">
            <img src="{{feature_image}}"
                 alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                 loading="eager">
        </div>
        {{/if}}
    {{/if}}

    <div class="container">
        <div class="post-full__inner">
            {{#if @page.show_title_and_feature_image}}
            <header class="post-full__header">
                <h1 class="post-full__title">{{title}}</h1>
                {{#if custom_excerpt}}
                <p class="post-full__excerpt">{{custom_excerpt}}</p>
                {{/if}}
            </header>
            {{/if}}
            <div class="post-full__content gh-content">
                {{content}}
            </div>
        </div>
    </div>
</article>
{{/post}}
